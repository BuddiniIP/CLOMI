<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".activities.onboarding.SleepSetupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back -->

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary" />

        <!-- Progress -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

        </LinearLayout>

        <!-- Icon -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="😴"
            android:textSize="64sp"/>

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Sleep Goal"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <!-- Subtitle -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Choose your preferred sleep duration."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"/>

        <!-- Sleep Goal -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <RadioGroup
                android:id="@+id/rgSleepHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <RadioButton
                    android:id="@+id/rb6Hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 Hours"/>

                <RadioButton
                    android:id="@+id/rb7Hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 Hours"/>

                <RadioButton
                    android:id="@+id/rb8Hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8 Hours (Recommended)"/>

                <RadioButton
                    android:id="@+id/rb9Hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9 Hours"/>

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>

        <!-- Reminder -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Sleep Reminder"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchReminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Recommendation -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/primary_light"
            app:cardCornerRadius="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="Recommendation&#10;&#10;Adults generally benefit from 7–9 hours of sleep each night."
                android:textColor="@color/text_primary"
                android:textSize="15sp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Continue -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="24dp"
            android:text="Continue"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</ScrollView>