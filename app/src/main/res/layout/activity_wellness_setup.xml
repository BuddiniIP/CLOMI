<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".activities.onboarding.WellnessSetupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"/>

        <!-- Progress -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="😊"
            android:textSize="64sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/wellness_title"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/wellness_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"/>

        <!-- Mood Check -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/mood_freq_label"
            android:textStyle="bold"
            android:textSize="17sp"/>

        <RadioGroup
            android:id="@+id/rgMoodFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mood_daily"/>

            <RadioButton
                android:id="@+id/rbWeekly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mood_weekly"/>

            <RadioButton
                android:id="@+id/rbNeeded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mood_needed"/>

        </RadioGroup>

        <!-- Motivation -->

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchMotivation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/motivation_switch"/>

        <!-- Improve -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/improve_label"
            android:textStyle="bold"
            android:textSize="17sp"/>

        <CheckBox
            android:id="@+id/cbConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/improve_confidence"/>

        <CheckBox
            android:id="@+id/cbStress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/improve_stress"/>

        <CheckBox
            android:id="@+id/cbProductivity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/improve_productivity"/>

        <CheckBox
            android:id="@+id/cbSelfCare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/improve_self_care"/>

        <CheckBox
            android:id="@+id/cbMental"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/improve_mental"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#FFF8E1">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="@string/wellness_tip"
                android:textColor="@color/text_primary"/>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:text="@string/finish_setup"
            android:textAllCaps="false"
            android:textSize="17sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="18dp"/>

    </LinearLayout>

</ScrollView>
