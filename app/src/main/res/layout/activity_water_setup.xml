<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".activities.onboarding.WaterSetupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back Button -->

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary" />

        <!-- Progress -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

        </LinearLayout>

        <!-- Icon -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="💧"
            android:textSize="64sp" />

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Daily Water Goal"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Subtitle -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Choose your daily water intake goal."
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <!-- Water Goal Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <RadioGroup
                android:id="@+id/rgWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <RadioButton
                    android:id="@+id/rbWater15"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.5 Litres" />

                <RadioButton
                    android:id="@+id/rbWater20"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.0 Litres" />

                <RadioButton
                    android:id="@+id/rbWater25"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.5 Litres" />

                <RadioButton
                    android:id="@+id/rbWater30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3.0 Litres" />

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>

        <!-- Recommendation -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/blue"
            app:cardCornerRadius="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="Recommendation&#10;&#10;Most adults benefit from drinking around 2–3 litres of water each day."
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Continue -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="24dp"
            android:text="Continue"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/blue"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>