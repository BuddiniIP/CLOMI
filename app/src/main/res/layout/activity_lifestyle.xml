<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".activities.onboarding.LifestyleActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back -->

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary" />

        <!-- Progress -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive" />

        </LinearLayout>

        <!-- Icon -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="🌱"
            android:textSize="60sp" />

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lifestyle_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/lifestyle_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <!-- Gender -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/gender_label"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender_female" />

            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender_male" />

            <RadioButton
                android:id="@+id/rbPrefer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender_prefer" />

        </RadioGroup>

        <!-- Activity -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/activity_label"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbNotActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_not_active" />

            <RadioButton
                android:id="@+id/rbLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_light" />

            <RadioButton
                android:id="@+id/rbModerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_moderate" />

            <RadioButton
                android:id="@+id/rbVery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_very" />

        </RadioGroup>

        <!-- Goals -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="What would you like to focus on?"
            android:textSize="18sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbHabit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Build Better Habits" />

        <CheckBox
            android:id="@+id/cbCare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Improve Self Care" />

        <CheckBox
            android:id="@+id/cbWellness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Improve Wellness" />

        <CheckBox
            android:id="@+id/cbProductivity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Increase Productivity" />

        <CheckBox
            android:id="@+id/cbStress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reduce Stress" />

        <!-- Recommendation -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/primary_light"
            app:cardCornerRadius="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="Select one or more focus areas. CLOMI will personalize your experience based on your choices."
                android:textColor="@color/text_primary" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Continue -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="24dp"
            android:text="@string/continue_btn"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>