<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".activities.onboarding.LifestyleActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back -->

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"/>

        <!-- Progress -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_active"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/dot_inactive"/>

        </LinearLayout>

        <!-- Plant -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="🌱"
            android:textSize="60sp"
            tools:ignore="HardcodedText" />

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lifestyle_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/lifestyle_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"/>

        <!-- Gender -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/gender_label"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender_female"/>

            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender_male"/>

            <RadioButton
                android:id="@+id/rbPrefer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender_prefer"/>

        </RadioGroup>

        <!-- Activity -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/activity_label"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <RadioGroup
            android:id="@+id/rgActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbNotActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_not_active"/>

            <RadioButton
                android:id="@+id/rbLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_light"/>

            <RadioButton
                android:id="@+id/rbModerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_moderate"/>

            <RadioButton
                android:id="@+id/rbVery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_very"/>

        </RadioGroup>

        <!-- Goal -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/goal_label"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <RadioGroup
            android:id="@+id/rgGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbHabit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/goal_habit"/>

            <RadioButton
                android:id="@+id/rbCare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/goal_care"/>

            <RadioButton
                android:id="@+id/rbWellness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/goal_wellness"/>

            <RadioButton
                android:id="@+id/rbProductivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/goal_productivity"/>

            <RadioButton
                android:id="@+id/rbStress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/goal_stress"/>

        </RadioGroup>

        <!-- Tip -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:cardBackgroundColor="@color/primary_light"
            app:cardCornerRadius="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="@string/lifestyle_tip"
                android:textColor="@color/text_primary"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Continue -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="24dp"
            android:text="@string/continue_btn"
            android:textAllCaps="false"
            android:textSize="17sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="18dp"/>

    </LinearLayout>

</ScrollView>
